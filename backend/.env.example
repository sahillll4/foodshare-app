# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database (Supabase PostgreSQL + PostGIS) ─────────────────────────────────
# Get this from: Supabase > Settings > Database > Connection String > URI
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-long-random-secret-before-production"
JWT_EXPIRES_IN="30d"

# ─── Firebase (Auth + FCM) ────────────────────────────────────────────────────
# Download from: Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com"
# Replace newlines with \n in this string
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ─── Cloudinary (Image Upload) ────────────────────────────────────────────────
# Get from: Cloudinary Console > Dashboard
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── Redis (Bull Queues + Cache) ──────────────────────────────────────────────
# Local dev: redis://localhost:6379
# Railway: copy from Railway Redis plugin
REDIS_URL="redis://localhost:6379"

# ─── App Config ───────────────────────────────────────────────────────────────
# Max radius for nearby listings search (in meters)
DEFAULT_SEARCH_RADIUS_M=5000
# How long a claim is reserved before auto-release (in minutes)
CLAIM_EXPIRY_MINUTES=30
# Impact points awarded per completed courier delivery
COURIER_POINTS_PER_DELIVERY=10
# Minimum time left on listing before it can be claimed (in minutes)
MIN_CLAIMABLE_MINUTES=30
